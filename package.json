{
  "name": "@fragments-sdk/ui",
  "version": "0.8.1",
  "license": "MIT",
  "description": "Customizable UI components built on Base UI headless primitives",
  "repository": {
    "type": "git",
    "url": "https://github.com/ConanMcN/fragments"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "fragments": "fragments.json",
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles/globals.scss",
    "./tokens": "./src/tokens/_variables.scss",
    "./mixins": "./src/tokens/_mixins.scss",
    "./brand": "./src/brand.ts",
    "./fragments.json": "./fragments.json",
    "./assets/*": "./src/assets/*",
    "./package.json": "./package.json"
  },
  "keywords": [
    "react",
    "components",
    "ui-library",
    "design-system",
    "typescript",
    "accessible",
    "base-ui",
    "theming",
    "design-tokens",
    "headless-ui",
    "react-components"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "node ../../packages/cli/dist/bin.js dev",
    "build": "node ../../packages/cli/dist/bin.js build",
    "lint": "eslint src",
    "validate": "node ../../packages/cli/dist/bin.js validate",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-markdown": ">=9.0.0",
    "recharts": ">=2.0.0 || >=3.0.0",
    "remark-gfm": ">=4.0.0",
    "react-day-picker": ">=9.0.0",
    "date-fns": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react-markdown": {
      "optional": true
    },
    "recharts": {
      "optional": true
    },
    "remark-gfm": {
      "optional": true
    },
    "react-day-picker": {
      "optional": true
    },
    "date-fns": {
      "optional": true
    }
  },
  "scarfSettings": {
    "defaultOptIn": true
  },
  "dependencies": {
    "@scarf/scarf": "^1.4.0",
    "@base-ui/react": "^1.0.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-table": "^8.21.3",
    "react-colorful": "^5.6.1",
    "shiki": "^3.0.0"
  },
  "devDependencies": {
    "@fragments-sdk/cli": "workspace:*",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass": "^1.83.0",
    "typescript": "^5.7.0",
    "react-day-picker": "^9.0.0",
    "date-fns": "^4.0.0",
    "vitest": "^2.1.8",
    "vitest-axe": "^0.1.0"
  },
  "files": [
    "src",
    "fragments.json"
  ]
}
